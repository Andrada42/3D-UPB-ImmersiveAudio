# Base: https://github.com/github/gitignore/blob/main/Unity.gitignore

# === Unity (3D-UPB-ImmersiveAudio/) ===

3D-UPB-ImmersiveAudio/.utmp/
3D-UPB-ImmersiveAudio/[Ll]ibrary/
3D-UPB-ImmersiveAudio/[Tt]emp/
3D-UPB-ImmersiveAudio/[Oo]bj/
3D-UPB-ImmersiveAudio/[Bb]uild/
3D-UPB-ImmersiveAudio/[Bb]uilds/
3D-UPB-ImmersiveAudio/[Ll]ogs/
3D-UPB-ImmersiveAudio/[Uu]ser[Ss]ettings/
3D-UPB-ImmersiveAudio/*.log

3D-UPB-ImmersiveAudio/*.blend1
3D-UPB-ImmersiveAudio/*.blend1.meta

3D-UPB-ImmersiveAudio/[Mm]emoryCaptures/
3D-UPB-ImmersiveAudio/[Rr]ecordings/

# Autogenerated Jetbrains Rider plugin
3D-UPB-ImmersiveAudio/[Aa]ssets/Plugins/Editor/JetBrains*
3D-UPB-ImmersiveAudio/*.DotSettings.user

3D-UPB-ImmersiveAudio/.vs/
3D-UPB-ImmersiveAudio/.gradle/

3D-UPB-ImmersiveAudio/ExportedObj/
3D-UPB-ImmersiveAudio/.consulo/
3D-UPB-ImmersiveAudio/*.csproj
3D-UPB-ImmersiveAudio/*.unityproj
3D-UPB-ImmersiveAudio/*.sln
3D-UPB-ImmersiveAudio/*.slnx
3D-UPB-ImmersiveAudio/*.suo
3D-UPB-ImmersiveAudio/*.tmp
3D-UPB-ImmersiveAudio/*.user
3D-UPB-ImmersiveAudio/*.userprefs
3D-UPB-ImmersiveAudio/*.pidb
3D-UPB-ImmersiveAudio/*.booproj
3D-UPB-ImmersiveAudio/*.svd
3D-UPB-ImmersiveAudio/*.pdb
3D-UPB-ImmersiveAudio/*.mdb
3D-UPB-ImmersiveAudio/*.opendb
3D-UPB-ImmersiveAudio/*.VC.db

# Unity3D generated meta files
3D-UPB-ImmersiveAudio/*.pidb.meta
3D-UPB-ImmersiveAudio/*.pdb.meta
3D-UPB-ImmersiveAudio/*.mdb.meta

3D-UPB-ImmersiveAudio/sysinfo.txt
3D-UPB-ImmersiveAudio/mono_crash.*

# Builds
3D-UPB-ImmersiveAudio/*.apk
3D-UPB-ImmersiveAudio/*.aab
3D-UPB-ImmersiveAudio/*.unitypackage
3D-UPB-ImmersiveAudio/*.unitypackage.meta
3D-UPB-ImmersiveAudio/*.app

3D-UPB-ImmersiveAudio/crashlytics-build.properties
3D-UPB-ImmersiveAudio/InitTestScene*.unity*

# Addressables
3D-UPB-ImmersiveAudio/ServerData
3D-UPB-ImmersiveAudio/[Aa]ssets/StreamingAssets/aa*
3D-UPB-ImmersiveAudio/[Aa]ssets/AddressableAssetsData/link.xml*
3D-UPB-ImmersiveAudio/[Aa]ssets/Addressables_Temp*
3D-UPB-ImmersiveAudio/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
3D-UPB-ImmersiveAudio/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
3D-UPB-ImmersiveAudio/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
3D-UPB-ImmersiveAudio/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
3D-UPB-ImmersiveAudio/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

3D-UPB-ImmersiveAudio/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
3D-UPB-ImmersiveAudio/[Aa]ssets/[Ss]ceneDependencyCache*

# === FMOD Unity plugin (3D-UPB-ImmersiveAudio/) ===

3D-UPB-ImmersiveAudio/**/FMODStudioCache.asset
3D-UPB-ImmersiveAudio/[Aa]ssets/Plugins/FMOD/Cache/*

# Never ignore the FMOD libs / editor icons
!3D-UPB-ImmersiveAudio/[Aa]ssets/Plugins/FMOD/**/lib/*
!3D-UPB-ImmersiveAudio/[Aa]ssets/Gizmos/FMOD/*
!3D-UPB-ImmersiveAudio/[Aa]ssets/Editor Default Resources/FMOD/*

3D-UPB-ImmersiveAudio/[Aa]ssets/StreamingAssets/**/*.bank
3D-UPB-ImmersiveAudio/[Aa]ssets/StreamingAssets/**/*.bank.meta

# === FMOD Studio project (FMOD/<project>/) ===

FMOD/**/.cache/
FMOD/**/.user/
FMOD/**/*.user
FMOD/**/.unsaved/
FMOD/**/.restore/
FMOD/**/Build/
FMOD/**/Metadata/Workspace.xml

# === OS / IDE ===

.idea/
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~
